ticker: "{{ ticker }}"
type: trading-position
status: "{{ status }}"
shares: {{ shares }}
avg_cost: {{ "%.2f"|format(avg_cost) }}
cost_basis: {{ "%.2f"|format(cost_basis) }}
{% if strategy -%}
strategy: "{{ strategy }}"
{% endif -%}
first_trade: "{{ first_trade }}"
last_trade: "{{ last_trade }}"
trade_count: {{ trade_count }}
tags:
  - trading
  - position
